# Yuval Fit OS — Beta Access System environment variables.
#
# Copy this file to `.env.local` (which is gitignored) and fill in the values
# from your Supabase project: Project Settings → API.
#
# These are the PUBLIC client keys. They are safe to expose in the browser
# bundle — real access control comes from Row Level Security (see
# supabase/beta-access.sql), not from hiding these values.
#
# NEVER put the Supabase service-role key here or in any NEXT_PUBLIC_* variable.
# It must never reach the client.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-PUBLIC-ANON-KEY

# After setting these locally, also add them in Vercel:
#   Project → Settings → Environment Variables (Production + Preview + Development).

# ---------------------------------------------------------------------------
# TESTING SEAM — local development and automated QA ONLY. NEVER set in production.
#
# When set to "1" the beta access gate is fully disabled and the app opens with
# no sign-in. This exists so the local QA harness can reach app screens without
# a live Supabase project. Leave it UNSET in any real deployment — the gate then
# fails closed by default.
# NEXT_PUBLIC_BETA_DISABLE_GATE=1

# ---------------------------------------------------------------------------
# NUTRITION PHOTO ASSIST (Phase 3.xx) — server-side vision for photo-first
# nutrition logging. These are SERVER-ONLY secrets — NEVER prefix with
# NEXT_PUBLIC. When no key (and no mock) is configured the feature is hidden
# cleanly: the "סרוק צלחת" card does not render and manual/recent logging works
# normally. See docs/NUTRITION_PHOTO_ASSIST.md.
#
# Secret vision API key (falls back to ANTHROPIC_API_KEY if unset).
# NUTRITION_AI_API_KEY=sk-...
# Vision model id (optional; defaults to claude-sonnet-4-6).
# NUTRITION_AI_MODEL=claude-sonnet-4-6
# Testing/QA seam: "1" returns a deterministic mock draft with NO network call.
# Leave UNSET in real deployments.
# NUTRITION_AI_MOCK=1
